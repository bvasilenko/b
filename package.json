{
  "name": "@booga/bsuite-bindings",
  "version": "0.1.0",
  "description": "Agent-substrate binding for the b-* command-line tools. Installs Claude Code skills, Codex AGENTS template, and Cursor rules so autonomous LLM-agent loops discover and invoke the binaries automatically.",
  "type": "module",
  "bin": {
    "bsuite-bindings": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "agents-md",
    "cursor-rules",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src tests --max-warnings 0"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "tmp-promise": "^3.0.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
